{
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "面向高阶用户的 Redis 关键指标看板，聚焦热点、尾延迟和资源退化。",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "🔍 SLO 核心指标",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum(rate(redis_commands_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "总 QPS",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum(rate(redis_commands_total{instance=~\"$instance\", cmd=~\"get|mget|hget|hgetall\"}[1m]))",
          "legendFormat": "读 QPS",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum(rate(redis_commands_total{instance=~\"$instance\", cmd=~\"set|mset|hset|hmset|del\"}[1m]))",
          "legendFormat": "写 QPS",
          "refId": "C"
        }
      ],
      "title": "请求 QPS",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 85
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "100 * (sum(rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m])) / (sum(rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m])) + sum(rate(redis_keyspace_misses_total{instance=~\"$instance\"}[5m]))))",
          "legendFormat": "实时命中率",
          "refId": "A"
        }
      ],
      "title": "实时命中率",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "topk(3, (sum by (cmd) (rate(redis_commands_duration_seconds_total{instance=~\"$instance\", cmd!=\"\"}[5m])) / clamp_min(sum by (cmd) (rate(redis_commands_total{instance=~\"$instance\", cmd!=\"\"}[5m])), 1e-9))) * 1000",
          "legendFormat": "{{cmd}} 平均延迟",
          "refId": "A"
        }
      ],
      "title": "热点命令平均延迟",
      "type": "timeseries"
    },
