          "legendFormat": "等待次数 /s",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "rate(mysql_global_status_innodb_row_lock_time{instance=\"$host\"}[5m]) / clamp_min(rate(mysql_global_status_innodb_row_lock_waits{instance=\"$host\"}[5m]), 1e-9)",
          "legendFormat": "平均等待 (ms)",
          "refId": "B"
        }
      ],
      "title": "行锁等待",
      "type": "timeseries"
