    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "(1 - (rate(mysql_global_status_innodb_buffer_pool_reads{instance=\"$host\"}[5m]) / clamp_min(rate(mysql_global_status_innodb_buffer_pool_read_requests{instance=\"$host\"}[5m]), 1))) * 100",
          "legendFormat": "命中率",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "(mysql_global_status_buffer_pool_pages{instance=\"$host\",state=\"dirty\"} / clamp_min(sum without(state) (mysql_global_status_buffer_pool_pages{instance=\"$host\"}), 1)) * 100",
          "legendFormat": "脏页占比",
          "refId": "B"
        }
      ],
      "title": "Buffer Pool 健康",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
