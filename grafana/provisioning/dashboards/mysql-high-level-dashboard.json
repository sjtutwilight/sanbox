          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum(rate(node_disk_read_time_ms{instance=\"$host\",device!~\"dm-.+\"}[5m]) / clamp_min(rate(node_disk_reads_completed{instance=\"$host\",device!~\"dm-.+\"}[5m]), 1))",
